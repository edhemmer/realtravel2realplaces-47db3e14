{
  "rewrites": [
    {
      "source": "/((?!api/|assets/|favicon\\.png|favicon\\.ico|pwa-icon-192\\.png|pwa-icon-512\\.png|rt2rp-logo\\.png|manifest\\.webmanifest|sw\\.js|workbox-.*\\.js).*)",
      "destination": "/index.html"
    }
  ],
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        {
          "key": "X-Content-Type-Options",
          "value": "nosniff"
        },
        {
          "key": "Referrer-Policy",
          "value": "strict-origin-when-cross-origin"
        },
        {
          "key": "Permissions-Policy",
          "value": "camera=(), microphone=(), geolocation=(self)"
        }
      ]
    }
  ]
}
